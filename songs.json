---
layout: null
---
[
  {%- for song in site.data.songs -%}
    {
      "title": {{ song.title | jsonify }},
      "artist": {{ song.artist | jsonify }},
      "piano": {{ song.piano }},
      "guitar": {{ song.guitar }},
      "readiness": {{ song.readiness }},
      "url": {{ song.slug | prepend: "/songbook/songs/" | jsonify }}
    }{%- unless forloop.last -%},{%- endunless -%}
  {%- endfor -%}
]
